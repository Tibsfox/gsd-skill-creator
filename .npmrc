engine-strict=true
# tree-sitter-glsl@0.2.0 (latest) declares peer tree-sitter@^0.22.1 but we
# use ^0.25.0 to match the rest of the tree-sitter-* family. No newer GLSL
# pack is available upstream; the conflict is benign at runtime (parser
# bindings load fine; verified across Phase 822 + 827 vitest suites).
# Without this flag, `npm ci` fails ERESOLVE; npm 7+ enforces strict peer
# resolution by default. Drop this line if a tree-sitter@^0.25-compatible
# tree-sitter-glsl ships upstream.
legacy-peer-deps=true
