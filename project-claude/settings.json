{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-state.cjs"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/worktree-init.cjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/worktree-cleanup.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-save-work-state.js"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-snapshot-session.js"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-compact-snapshot.cjs"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-compact-recovery.cjs"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tool-tracker.sh"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tool-tracker.sh"
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tool-tracker.sh"
          }
        ]
      }
    ],
    "SubagentSpawn": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tool-tracker.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tool-tracker.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tool-tracker.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/notification-logger.cjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/validate-commit.cjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/phase-boundary-check.cjs"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-response-scan.cjs"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/observe-tool-trace.cjs"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node .claude/hooks/gsd-statusline.js"
  },
  "feature_flags": {
    "autonomous_phase_execution": false,
    "autonomous_milestone_execution": false,
    "autonomous_commit_push": false,
    "autonomous_pr_create": false,
    "autonomous_pr_merge": false,
    "memory_scorer_aggressive_threshold": false,
    "memory_scorer_eager_eviction": false,
    "memory_scorer_disable_dedupe": false,
    "experimental_runtime_pi": false,
    "experimental_runtime_codex": false,
    "experimental_runtime_gemini": false,
    "experimental_runtime_cursor": false,
    "bounded_learning_disabled": false,
    "bounded_learning_relax_caps": false,
    "bounded_learning_skip_cooldown": false,
    "lyapunov_gate_disabled": false,
    "lyapunov_relax_certificate": false,
    "tractability_classifier_disabled": false,
    "tractability_skip_escalation": false,
    "stochastic_selection_disabled": false,
    "langevin_noise_disabled": false,
    "temperature_annealing_disabled": false,
    "feature_flags_admin_writeable": false,
    "skill_auto_install": false,
    "skill_auto_update": false,
    "skill_publish_skip_gate": false,
    "agent_subagent_skip_effort_param": false,
    "tool_tracker_capture_full_payload": false,
    "tool_tracker_capture_filechanged_contents": false,
    "tool_tracker_disabled": false,
    "telemetry_export_remote": false,
    "telemetry_pii_capture_allowed": false,
    "session_observe_aggressive_capture": false,
    "session_retro_auto_publish": false,
    "ab_harness_skip_significance_gate": false,
    "branch_context_skip_lifecycle": false,
    "decision_trace_disabled": false,
    "graph_query_disabled": false,
    "orchestration_loop_unbounded": false,
    "model_affinity_disabled": false,
    "model_affinity_force_haiku": false,
    "model_affinity_force_opus": false,
    "experimental_quintessence_report": false,
    "experimental_dual_impl_promotion": false
  }
}
