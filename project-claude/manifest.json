{
  "version": 2,
  "project": "gsd-skill-creator",
  "description": "Project-specific .claude files that extend GSD framework",
  "files": {
    "autoDiscover": [
      {
        "kind": "agents",
        "source_dir": "agents",
        "target_dir": ".claude/agents",
        "pattern": "*.md",
        "description": "Auto-install any .md file under project-claude/agents/ not otherwise listed."
      },
      {
        "kind": "skills",
        "source_dir": "skills",
        "target_dir": ".claude/skills",
        "pattern": "*/SKILL.md",
        "description": "Auto-install any project-claude/skills/<name>/SKILL.md not otherwise listed."
      },
      {
        "kind": "hook-scripts",
        "source_dir": "hooks",
        "target_dir": ".claude/hooks",
        "pattern": ["*.cjs", "*.sh"],
        "exclude": ["hooks/post-commit"],
        "description": "Auto-install any project-claude/hooks/*.cjs or *.sh not otherwise listed. Routed through installHookScript for executable bit. .js hooks are handled via standalone[]; post-commit is the git hook installed separately."
      }
    ],
