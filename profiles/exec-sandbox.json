{
  "agent_type": "exec",
  "description": "Exec agent sandbox profile — worktree-only write access, credential directories denied at READ level",
  "write_dirs": [
    "$WORKTREE"
  ],
  "deny_read_dirs": [
    "$HOME/.ssh",
    "$HOME/.config",
    "$HOME/.aws"
  ],
  "allowed_domains": [
    "api.anthropic.com",
    "github.com",
    "registry.npmjs.org"
  ],
  "proxy_socket": "$PROJECT/.planning/security/proxy.sock",
  "bwrap_flags": {
    "die_with_parent": true,
    "cap_drop": "ALL",
    "unshare_net": true,
    "unshare_pid": true,
    "unshare_uts": true,
    "restricted_proc": true
  }
}
