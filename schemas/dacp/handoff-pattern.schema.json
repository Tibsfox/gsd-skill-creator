{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gsd.tools/schemas/dacp/handoff-pattern.schema.json",
  "description": "DACP Handoff Pattern: recurring handoff type with aggregated drift statistics and fidelity recommendations.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "source_agent_type": {
      "type": "string"
    },
    "target_agent_type": {
      "type": "string"
    },
    "opcode": {
      "type": "string",
      "enum": [
        "EXEC",
        "VERIFY",
        "TRANSFORM",
        "CONFIG",
        "RESEARCH",
        "REPORT",
        "QUESTION",
        "PATCH",
        "ALERT"
      ]
    },
    "observed_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "avg_drift_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "max_drift_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "current_fidelity": {
      "anyOf": [
        {
          "type": "number",
          "const": 0
        },
        {
          "type": "number",
          "const": 1
        },
        {
          "type": "number",
          "const": 2
        },
        {
          "type": "number",
          "const": 3
        },
        {
          "type": "number",
          "const": 4
        }
      ]
    },
    "recommended_fidelity": {
      "anyOf": [
        {
          "type": "number",
          "const": 0
        },
        {
          "type": "number",
          "const": 1
        },
        {
          "type": "number",
          "const": 2
        },
        {
          "type": "number",
          "const": 3
        },
        {
          "type": "number",
          "const": 4
        }
      ]
    },
    "last_observed": {
      "type": "string"
    },
    "promotion_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": {
            "anyOf": [
              {
                "type": "number",
                "const": 0
              },
              {
                "type": "number",
                "const": 1
              },
              {
                "type": "number",
                "const": 2
              },
              {
                "type": "number",
                "const": 3
              },
              {
                "type": "number",
                "const": 4
              }
            ]
          },
          "to": {
            "anyOf": [
              {
                "type": "number",
                "const": 0
              },
              {
                "type": "number",
                "const": 1
              },
              {
                "type": "number",
                "const": 2
              },
              {
                "type": "number",
                "const": 3
              },
              {
                "type": "number",
                "const": 4
              }
            ]
          },
          "reason": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          }
        },
        "required": [
          "from",
          "to",
          "reason",
          "timestamp"
        ],
        "additionalProperties": false
      }
    },
    "contributing_bundles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "id",
    "type",
    "source_agent_type",
    "target_agent_type",
    "opcode",
    "observed_count",
    "avg_drift_score",
    "max_drift_score",
    "current_fidelity",
    "recommended_fidelity",
    "last_observed",
    "promotion_history",
    "contributing_bundles"
  ],
  "additionalProperties": false
}
