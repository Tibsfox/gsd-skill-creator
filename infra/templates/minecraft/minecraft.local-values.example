# Minecraft Server Deployment Local Values
# Copy to infra/local/minecraft.local-values and edit for your site.
# Rendered by: infra/scripts/deploy-minecraft.sh
#
# Variable mapping: lower_snake_case here -> UPPER_SNAKE_CASE in templates
# Example: jvm_heap_min_mb -> ${JVM_HEAP_MIN_MB} in jvm-flags.conf.template
#
# Most JVM values can be auto-populated from infra/local/local-values.yaml
# (generated by generate-local-values.sh from your hardware profile).
# This file allows overrides and adds deployment-specific settings.
#
# Templates consumed:
#   - infra/templates/minecraft/jvm-flags.conf.template
#   - infra/templates/minecraft/minecraft.service.template
#
# Never commit actual secrets or site-specific values to version control.
# This is an EXAMPLE file only.

# ============================================================
# Fabric Installer
# ============================================================

# Fabric installer version
# Check https://fabricmc.net/use/installer/ for latest
fabric_installer_version: "1.0.1"

# Minecraft game version
# Must match the version your mods are built for
minecraft_version: "1.21.4"

# Fabric loader version
# Use "latest" to fetch the newest compatible loader, or pin a specific version
fabric_loader_version: "latest"

# ============================================================
# Server Identity
# ============================================================

# Root directory for the Minecraft installation on the target VM
# Created by kickstart (Phase 171) with minecraft:minecraft ownership
minecraft_home: "/opt/minecraft"

# Server JAR filename produced by the Fabric installer
# Default is "fabric-server-launch.jar" -- do not change unless you know what you are doing
server_jar: "fabric-server-launch.jar"

# ============================================================
# JVM Configuration (from hardware profile or manual override)
# ============================================================
# These values override the minecraft.jvm section from local-values.yaml
# if set here. Remove a line to fall back to the hardware-profile-generated value.

# Minimum JVM heap size in megabytes
# Should be equal to or less than heap_max_mb
# Tier defaults: minimal=1024, comfortable=2048, generous=4096
jvm_heap_min_mb: "4096"

# Maximum JVM heap size in megabytes
# Formula: (minecraft_vm_ram_gb * 1024) - 512 (leave headroom for OS + JVM overhead)
# Tier defaults: minimal=3584, comfortable=7680, generous=15872
jvm_heap_max_mb: "15872"

# Garbage collector type (for documentation/comments only)
# ZGC recommended for heap >= 8GB, G1GC for smaller heaps
gc_type: "ZGC"

# Garbage collector flags passed directly to the JVM
# ZGC (heap >= 8GB):  "-XX:+UseZGC -XX:+ZGenerational"
# G1GC (heap < 8GB):  "-XX:+UseG1GC"
gc_flags: "-XX:+UseZGC -XX:+ZGenerational"

# Additional JVM flags for performance tuning
# These are appended after the GC flags
extra_jvm_flags: "-XX:+ParallelRefProcEnabled -XX:+DisableExplicitGC -XX:+AlwaysPreTouch"

# ============================================================
# JVM Flags Output Path (on target VM)
# ============================================================

# Path where the rendered jvm-flags.conf will be installed on the target
# Referenced by the systemd EnvironmentFile directive
jvm_flags_path: "/opt/minecraft/server/jvm-flags.conf"

# ============================================================
# Network
# ============================================================

# Minecraft game port (clients connect here)
# Must match the firewall port opened by kickstart (Phase 171)
minecraft_server_port: "25565"

# RCON (Remote Console) port for server management
# Must match the firewall port opened by kickstart (Phase 171)
minecraft_rcon_port: "25575"

# Management network interface for firewall rules
# Should match the primary ethernet interface on the target VM
management_interface: "enp3s0"

# ============================================================
# EULA
# ============================================================

# You MUST agree to the Minecraft EULA to run the server
# https://www.minecraft.net/en-us/eula
# Set to "true" to accept -- the deploy script will NOT start the server
# unless this is "true"
minecraft_eula: "true"

# ============================================================
# SSH Target (for remote deployment)
# ============================================================

# SSH user@host for remote deployment (used with --target-host)
# The user must have sudo privileges on the target VM
# Example: gsd@mc-server-01
# target_host: "gsd@mc-server-01"
