{
  "name": "gsd-skill-creator",
  "version": "1.49.921",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "skill-creator": "dist/cli.js",
    "gsd-skill-creator": "project-claude/install.cjs"
  },
  "files": [
    "dist",
    "project-claude",
    "examples/cartridges/gsd-skill-creator",
    "examples/cartridges/get-shit-done",
    "examples/cartridges/release-engine",
    "examples/cartridges/housekeeping"
  ],
  "description": "Adaptive learning layer for Claude Code — skills, agents, teams, and chipsets",
  "author": "Tibsfox",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tibsfox/gsd-skill-creator.git"
  },
  "keywords": [
    "claude-code",
    "ai-agents",
    "skills",
    "gsd",
    "adaptive-learning",
    "claude",
    "anthropic"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "postinstall": "bash tools/install-git-hooks.sh || true",
    "version:check": "node scripts/bump-version.mjs --check",
    "version:bump": "node scripts/bump-version.mjs",
    "version": "node scripts/bump-version.mjs --from-npm && git add package.json package-lock.json src-tauri/Cargo.toml src-tauri/tauri.conf.json",
    "pre-tag-gate": "bash tools/pre-tag-gate.sh",
    "adoption-report": "node tools/adoption-scan.mjs",
    "adoption-report:json": "node tools/adoption-scan.mjs --json",
    "adoption-report:refresh": "node tools/adoption-refresh.mjs",
    "adoption-report:trends": "node tools/adoption-trends.mjs --write",
    "adoption-report:trends:check": "node tools/adoption-trends.mjs --check",
    "adoption-report:dashboard": "node tools/adoption-scan.mjs --json | node tools/render-adoption-dashboard.mjs",
    "depth-audit": "node tools/depth-audit.mjs",
    "depth-audit:current": "node tools/depth-audit.mjs --current",
    "scaffold:cross-track": "node tools/scaffold-cross-track-dirs.mjs",
    "scaffold:cross-track:dry-run": "node tools/scaffold-cross-track-dirs.mjs --dry-run",
    "ftp-sync": "node tools/ftp-sync.mjs",
    "ftp-sync:dry-run": "node tools/ftp-sync.mjs --dry-run",
    "ftp-sync:scribe": "node tools/ftp-sync.mjs scribe",
    "ftp-sync:scribe:dry-run": "node tools/ftp-sync.mjs scribe --dry-run",
    "ftp-delete": "node tools/ftp-delete.mjs",
    "ftp-delete:dry-run": "node tools/ftp-delete.mjs --dry-run",
    "build:www-bundles": "bash tools/build-www-bundles.sh",
    "render:claude-md": "node tools/render-claude-md.mjs",
    "render:claude-md:check": "node tools/render-claude-md.mjs --check",
    "render:claude-md:dry-run": "node tools/render-claude-md.mjs --dry-run",
    "render:claude-md:diff": "node tools/render-claude-md.mjs --diff",
    "bench": "vitest bench --run --config vitest.bench.config.mjs",
    "bench:check": "node tools/bench/check.mjs",
    "graph:load:trs": "node tools/load-trs-edges.mjs",
    "ship-sync": "bash tools/ship-sync.sh",
    "gh-release-publish": "bash tools/gh-release-publish.sh",
    "build": "tsc",
    "postbuild": "node scripts/postbuild.mjs",
    "dev": "tsx src/cli.ts",
    "test": "vitest --project root --project space-between",
    "test:integration": "vitest run --project integration",
    "test:perf": "vitest run --project intelligence-perf",
    "test:hooks": "bash tools/hook-tests-sterile.sh",
    "setup:claude": "skill-creator gsd-init",
    "setup:claude:force": "skill-creator gsd-init --force",
    "setup:claude:check": "skill-creator gsd-init --dry-run",
    "desktop:dev": "cd src-tauri && npx tauri dev",
    "desktop:build": "cd src-tauri && PKG_CONFIG_PATH=\"$(pwd)/.pkgconfig:${PKG_CONFIG_PATH:-}\" npx tauri build",
    "tauri:scribe": "cd src-tauri && npx tauri dev --no-watch",
    "desktop:test": "cd desktop && npx vitest run",
    "intelligence:build": "cd desktop && npx vite build && mkdir -p ../dashboard/intelligence ../dashboard/assets && cp dist/dashboard/intelligence/planning.bundle.js dist/dashboard/intelligence/live-work.bundle.js dist/dashboard/intelligence/atlas.bundle.js ../dashboard/intelligence/ && cp -r dist/assets/. ../dashboard/assets/",
    "intelligence:serve": "npm run intelligence:build && node scripts/serve-dashboard.mjs",
    "docs:api": "npx typedoc",
    "sync": "bash scripts/sync-research-to-live.sh --dry-run",
    "sync:live": "bash scripts/sync-research-to-live.sh",
    "deploy": "bash scripts/sync-research-to-live.sh",
    "state-md:check": "node tools/state-md-normalizer.mjs --check",
    "state-md:normalize": "node tools/state-md-normalizer.mjs --write"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.1",
    "@clack/prompts": "^1.0.0",
    "@mapbox/vector-tile": "^2.0.4",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-en": "^3.0.2",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "chromadb": "^3.4.3",
    "diff": "^8.0.3",
    "fast-xml-parser": "^5.8.0",
    "fastest-levenshtein": "^1.0.16",
    "flatgeobuf": "^4.4.0",
    "gpt-tokenizer": "^3.4.0",
    "gray-matter": "^4.0.3",
    "ignore": "^7.0.5",
    "js-yaml": "^4.1.1",
    "lru-cache": "^11.3.6",
    "marked": "^17.0.3",
    "modern-tar": "^0.7.3",
    "mysql2": "^3.22.2",
    "nanoid": "^3.3.12",
    "pg": "^8.20.0",
    "picocolors": "^1.1.1",
    "pmtiles": "^4.4.1",
    "simple-statistics": "^7.8.8",
    "tree-sitter": "^0.25.0",
    "tree-sitter-bash": "^0.25.1",
    "tree-sitter-glsl": "^0.2.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "vt-pbf": "^3.1.3",
    "yaml": "^2.9.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.8.1",
    "better-sqlite3": "^12.9.0"
  },
  "overrides": {
    "onnxruntime-node": "1.20.1",
    "@huggingface/transformers": {
      "sharp": "npm:empty-npm-package@1.0.0"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^7.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "better-sqlite3": "^12.9.0",
    "jsdom": "^29.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
