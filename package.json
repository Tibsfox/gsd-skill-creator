{
  "name": "gsd-skill-creator",
  "version": "1.49.561",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "skill-creator": "dist/cli.js",
    "gsd-skill-creator": "project-claude/install.cjs"
  },
  "files": [
    "dist",
    "project-claude",
    "examples/cartridges/gsd-skill-creator",
    "examples/cartridges/get-shit-done",
    "examples/cartridges/release-engine",
    "examples/cartridges/housekeeping"
  ],
  "description": "Adaptive learning layer for Claude Code — skills, agents, teams, and chipsets",
  "author": "Tibsfox",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tibsfox/gsd-skill-creator.git"
  },
  "keywords": [
    "claude-code",
    "ai-agents",
    "skills",
    "gsd",
    "adaptive-learning",
    "claude",
    "anthropic"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "version:check": "node scripts/bump-version.mjs --check",
    "version:bump": "node scripts/bump-version.mjs",
    "version": "node scripts/bump-version.mjs --from-npm && git add package.json package-lock.json src-tauri/Cargo.toml src-tauri/tauri.conf.json",
    "build": "tsc",
    "postbuild": "node scripts/postbuild.mjs",
    "dev": "tsx src/cli.ts",
    "test": "vitest --project root --project space-between",
    "test:integration": "vitest run --project integration",
    "setup:claude": "skill-creator gsd-init",
    "setup:claude:force": "skill-creator gsd-init --force",
    "setup:claude:check": "skill-creator gsd-init --dry-run",
    "desktop:dev": "cd src-tauri && npx tauri dev",
    "desktop:build": "cd src-tauri && PKG_CONFIG_PATH=\"$(pwd)/.pkgconfig:${PKG_CONFIG_PATH:-}\" npx tauri build",
    "desktop:test": "cd desktop && npx vitest run",
    "docs:api": "npx typedoc",
    "sync": "bash scripts/sync-research-to-live.sh --dry-run",
    "sync:live": "bash scripts/sync-research-to-live.sh",
    "deploy": "bash scripts/sync-research-to-live.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.1",
    "@clack/prompts": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "diff": "^8.0.3",
    "fastest-levenshtein": "^1.0.16",
    "gpt-tokenizer": "^3.4.0",
    "gray-matter": "^4.0.3",
    "gsd-pi": "^2.62.0",
    "js-yaml": "^4.1.1",
    "marked": "^17.0.3",
    "modern-tar": "^0.7.3",
    "pg": "^8.20.0",
    "picocolors": "^1.1.1",
    "simple-statistics": "^7.8.8",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.8.1",
    "better-sqlite3": "^12.9.0"
  },
  "overrides": {
    "onnxruntime-node": "1.20.1",
    "@huggingface/transformers": {
      "sharp": "npm:empty-npm-package@1.0.0"
    }
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/diff": "^7.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^29.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
