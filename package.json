{
  "name": "gsd-skill-creator",
  "version": "1.49.21",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "skill-creator": "./dist/cli.js"
  },
  "files": [
    "dist",
    "project-claude"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest",
    "test:integration": "vitest run --include '**/*.integration.test.ts'",
    "setup:claude": "skill-creator gsd-init",
    "setup:claude:force": "skill-creator gsd-init --force",
    "setup:claude:check": "skill-creator gsd-init --dry-run",
    "desktop:dev": "cd src-tauri && npx tauri dev",
    "desktop:build": "cd src-tauri && PKG_CONFIG_PATH=\"$(pwd)/.pkgconfig:${PKG_CONFIG_PATH:-}\" npx tauri build",
    "desktop:test": "cd desktop && npx vitest run",
    "docs:api": "npx typedoc"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.1",
    "@clack/prompts": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "diff": "^8.0.3",
    "fastest-levenshtein": "^1.0.16",
    "gpt-tokenizer": "^3.4.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "marked": "^17.0.3",
    "modern-tar": "^0.7.3",
    "picocolors": "^1.1.1",
    "simple-statistics": "^7.8.8",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.8.1"
  },
  "overrides": {
    "onnxruntime-node": "1.20.1",
    "@huggingface/transformers": {
      "sharp": "npm:empty-npm-package@1.0.0"
    }
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/diff": "^7.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
