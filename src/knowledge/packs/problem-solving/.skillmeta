# Standards Alignment
standards_alignment:
  - framework: "Common Core State Standards (Mathematical Practices)"
    version: 2010
    alignments:
      "CCSS.MATH.MP.1": "Make sense of problems and persevere"
      "CCSS.MATH.MP.2": "Reason abstractly and quantitatively"
      "CCSS.MATH.MP.3": "Construct viable arguments"
      "CCSS.MATH.MP.4": "Model with mathematics"
      "CCSS.MATH.MP.7": "Look for and make use of structure"
  - framework: "ISTE Standards for Students"
    version: 2016
    alignments:
      "5a": "Formulate problem definitions"
      "5b": "Collect and identify data sets"
      "5c": "Break problems into component parts"
      "5d": "Use algorithmic thinking"
  - framework: "IB Middle Years Programme (ATL - Approaches to Learning)"
    version: "2024"
    alignments:
      MYP.ATL.A: "Thinking skills"
      MYP.ATL.B: "Research skills"
  - framework: "UK National Curriculum (Problem Solving & Reasoning)"
    version: "2014"
    alignments:
      KS2.PS: "Problem-solving strategies"
      KS3.PS: "Complex problem decomposition"

# Difficulty Rating
difficulty:
  conceptual_demand: medium
  technical_demand: low
  prerequisites_required: low
  notes: "Difficulty is in developing habits of mind and strategic flexibility, not in technical content. Accessible to all learners with appropriate scaffolding."

# Content Flags
content_flags:
  - flag: frustration_potential
    description: "Genuinely novel problems can cause frustration in learners accustomed to exercises with clear procedures."
    mitigation: "Scaffold difficulty carefully. Celebrate strategy use and effort, not just correct answers. Normalize productive struggle explicitly."

  - flag: growth_mindset_dependency
    description: "Learners with fixed-mindset beliefs may resist the emphasis on effort and strategy over innate ability."
    mitigation: "Introduce growth mindset concepts early. Share research on how problem-solving skills improve with practice. Avoid labeling students as good or bad problem solvers."

