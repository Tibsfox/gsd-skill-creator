# Accessibility
accessibility:
  screen_reader_compatible: true
  large_text_available: true
  high_contrast_available: true
  keyboard_navigable: true
  alt_text_provided: true
  captions_available: false
  notes: "All visual content has text descriptions. Discussion-based activities include written alternatives. Argument mapping tools support keyboard navigation."

# Standards Alignment
standards_alignment:
  - framework: "Common Core ELA (Argumentation)"
    version: 2010
    alignments:
      CCRA.R.8: "Evaluate arguments and specific claims in a text"
      CCRA.W.1: "Write arguments to support claims with valid reasoning and evidence"
      CCRA.SL.3: "Evaluate a speaker's reasoning and use of evidence and rhetoric"

  - framework: "Philosophy for Children (P4C) Framework"
    version: 2020
    alignments:
      "Critical Thinking": true
      "Creative Thinking": true
      "Caring Thinking": true
      "Collaborative Thinking": true

# Difficulty Rating
difficulty:
  conceptual_demand: medium-high
  technical_demand: low
  prerequisites_required: low
  notes: "Conceptual demand increases significantly at middle and high school levels. Technical demand remains low -- critical thinking requires no special equipment, only disciplined practice."

# Content Flags
content_flags:
  - flag: worldview_sensitivity
    description: "Discussion of logical fallacies in religious, political, and cultural arguments may intersect with personal beliefs."
    mitigation: "Focus on the quality of reasoning rather than the truth of conclusions. Emphasize that fallacies are about HOW arguments are made, not WHAT is being argued. Apply the same analytical standards to all positions."

  - flag: emotional_difficulty
    description: "Discovering one's own cognitive biases and reasoning errors can be uncomfortable."
    mitigation: "Normalize bias as a universal human trait, not a personal failing. Frame bias awareness as empowerment. Use humor and self-deprecation to reduce defensiveness."

