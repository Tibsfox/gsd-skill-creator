    name: "Reasoning Discourse"
    frequency: ongoing

  - type: formative
    name: "Argument Analysis Review"
    frequency: weekly

  - type: summative
    name: "Critical Thinking Portfolio"
    frequency: end_of_unit

  - type: summative
    name: "Argument Evaluation Essay"
    frequency: end_of_module

