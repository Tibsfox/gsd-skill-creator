# Accessibility
accessibility:
  screen_reader_compatible: true
  large_text_available: true
  high_contrast_available: true
  keyboard_navigable: true
  alt_text_provided: true
  captions_available: false
  notes: "Hands-on activities have text descriptions. Consider adding video demonstrations with captions."

# Standards Alignment
standards_alignment:
  - framework: "ITEEA Standards for Technological and Engineering Literacy"
    version: 2020
    alignments:
      "1.A": "Characteristics and scope of technology"
      "2.A": "Core practices of technology"
      "3.A": "Contexts and applications"
      "4.A": "Characteristics of systemic design"
  - framework: "Next Generation Science Standards (Engineering)"
    version: 2013
    alignments:
      "K-2-ETS1-1": "Ask questions and define problems"
      "3-5-ETS1-1": "Define and delimit engineering problems"
      "MS-ETS1-1": "Define the criteria and constraints of design problems"
      "HS-ETS1-1": "Analyze a major global challenge"
      ETS1.A: "Defining and Delimiting Engineering Problems"
      ETS1.B: "Developing Possible Solutions"
      ETS1.C: "Optimizing the Design Solution"
  - framework: "IB Middle Years Programme (Design)"
    version: "2024"
    alignments:
      MYP.DES.A: "Investigating"
      MYP.DES.B: "Planning"
      MYP.DES.C: "Creating"
  - framework: "UK National Curriculum (Design & Technology)"
    version: "2014"
    alignments:
      KS1.DT: "Design, make, evaluate"
      KS2.DT: "Design and technology processes"
      KS3.DT: "Iterative design and making"

# Difficulty Rating
difficulty:
  conceptual_demand: medium
  technical_demand: low
  prerequisites_required: low
  notes: "Hands-on activities make concepts concrete; difficulty scales with module depth"

# Content Flags & Warnings
content_flags:
  - flag: tool_safety
    description: "Activities involve physical tools (scissors, hammers, saws for older students)"
    mitigation: "Safety guidelines included per activity; parental supervision recommended"

  - flag: environmental_topics
    description: "Module 5 discusses environmental impact of technology, which can feel overwhelming"
    mitigation: "Focus on agency and solutions alongside problems; avoid doom narratives"

