# Accessibility
accessibility:
  screen_reader_compatible: true
  large_text_available: true
  high_contrast_available: true
  keyboard_navigable: true
  alt_text_provided: true
  captions_available: false
  notes: "All visual content has text descriptions. Molecular models include textual descriptions of geometry. Kitchen chemistry activities use common, accessible materials. Consider adding video demonstrations with captions."

# Standards Alignment
standards_alignment:
  - framework: "Next Generation Science Standards (NGSS)"
    version: 2013
    alignments:
      PS1-A: "Structure and Properties of Matter"
      PS1-B: "Chemical Reactions"
      PS1-C: "Nuclear Processes"
      PS3-A: "Definitions of Energy"
      PS3-B: "Conservation of Energy and Energy Transfer"

  - framework: "AAAS Benchmarks for Science Literacy"
    version: 1993
    alignments:
      "Structure of Matter": true
      "Chemical Reactions": true
      "Energy Transformations": true

# Difficulty Rating
difficulty:
  conceptual_demand: medium-high
  technical_demand: low
  prerequisites_required: low
  notes: "Chemistry requires abstract thinking about invisible particles, which increases conceptual demand. However, kitchen chemistry activities make it tangible and accessible."

# Content Flags
content_flags:
  - flag: misconception_potential
    description: "Learners may think 'chemical' means 'dangerous' or 'artificial' due to everyday language."
    mitigation: "Explicitly teach that everything is made of chemicals. Water is a chemical. Oxygen is a chemical."

  - flag: safety_considerations
    description: "Some activities involve mild acids, bases, or heating. All activities use household materials but require supervision."
    mitigation: "Every activity includes safety guidelines. Dangerous reactions are excluded. Never mix bleach with ammonia or acids."

  - flag: abstract_concepts
    description: "Atomic structure and molecular bonding involve invisible entities that require abstract reasoning."
    mitigation: "Use physical models (candy atoms, gumdrop molecules) and simulations before introducing abstract representations."

