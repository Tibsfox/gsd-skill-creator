# Accessibility
accessibility:
  screen_reader_compatible: true
  large_text_available: true
  high_contrast_available: true
  keyboard_navigable: true
  alt_text_provided: true
  captions_available: true
  notes: |
    Audio content needs visual/text alternatives for deaf/hard of hearing learners. Sheet music requires accessible notation formats (Braille music notation for blind learners). Video demonstrations include captions and audio descriptions. Multiple participation modes: singing, playing, conducting, listening, rhythm (tactile vibration for non-auditory learners). Instrument descriptions with high-contrast illustrations."

# Standards Alignment
standards_alignment:
  - framework: "NCAS (National Core Arts Standards) Music"
    version: 2014
    alignments:
      "Creating (MU:Cr1.1)": "MUSIC-101-M1, M2, M5 (composition, improvisation)"
      "Creating (MU:Cr2.1)": "MUSIC-101-M5 (arrangement, recording)"
      "Performing (MU:Pr4.1)": "MUSIC-101-M1, M2, M3 (singing, instrumental performance)"
      "Responding (MU:Re7.1)": "MUSIC-101-M4 (listening, analysis)"
      "Connecting (MU:Cn10.1)": "MUSIC-101-M4 (music in cultural contexts)"

  - framework: "IB MYP Arts (Music)"
    version: 2016
    alignments:
      "Key Concept: Form": "MUSIC-101-M4 (structure, style)"
      "Key Concept: Communication": "MUSIC-101-M4, M5 (expression, cultural meaning)"
      "Key Concept: Process": "MUSIC-101-M1, M2, M5 (creative process, revision)"

  - framework: "UK National Curriculum Music"
    version: 2014
    alignments:
      "Key Stage 2": "MUSIC-101-M1, M2, M3 (foundation level)"
      "Key Stage 3": "MUSIC-101-M3, M4, M5 (middle school level)"
      "Key Stage 4": "MUSIC-101-M5 (specialist focus)"

  - framework: "Kodály and Orff Method Alignment"
    version: 2020
    alignments:
      "Orff-Schulwerk": "MUSIC-101-M1, M2, M3 (instruments, ensemble)"
      "Kodály Method": "MUSIC-101-M2 (solfège, vocal)"

# Difficulty Rating
difficulty:
  conceptual_demand: medium
  technical_demand: low
  prerequisites_required: low
  notes: "Difficulty scales with age level. Accessible to all learners regardless of prior experience. No expensive equipment required."

# Content Flags
content_flags:
  - flag: cultural_sensitivity
    description: "World music explorations require respectful, deep engagement with traditions"
    mitigation: "Use expert contributors from communities; avoid stereotyping; provide historical and cultural context"

  - flag: performance_anxiety
    description: "Some students may have anxiety about singing or performing in front of others"
    mitigation: "Provide small-group and solo options; celebrate effort over perfection; offer alternative participation modes"

