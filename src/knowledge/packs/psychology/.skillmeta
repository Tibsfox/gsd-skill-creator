    name: "Optical Illusion Gallery"

  - type: activity
    name: "Memory Palace Construction"

  - type: discussion
    name: "Empathy Circle"

  - type: reflection
    name: "Emotion Thermometer"

  - type: investigation
    name: "Cognitive Bias Detector"

