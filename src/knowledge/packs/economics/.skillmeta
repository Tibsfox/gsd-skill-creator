# Accessibility
accessibility:
  screen_reader_compatible: true
  large_text_available: true
  high_contrast_available: true
  keyboard_navigable: true
  alt_text_provided: true
  captions_available: false
  notes: "All visual content (graphs, tables) has text descriptions. Market simulations include text-based alternatives. Calculations emphasize conceptual understanding over speed."

# Standards Alignment
standards_alignment:
  - framework: "Common Core State Standards for Mathematics"
    version: 2010
    alignments:
      "7.RP": "Ratios and Proportional Relationships (prices, interest calculations)"
      "8.EE": "Expressions and Equations (algebra in financial planning)"

  - framework: "Next Generation Science Standards"
    version: 2013
    alignments:
      "Systems and System Models": true
      "Stability and Change": true

  - framework: "C3 Framework for Social Studies"
    version: 2013
    alignments:
      "Economics": "Earning, Producing, Consuming, and Distributing Goods and Services"
      "Civic and Political Institutions": true

# Difficulty Rating
difficulty:
  conceptual_demand: medium
  technical_demand: low
  prerequisites_required: low
  notes: "Difficulty is primarily conceptual (thinking in systems, considering multiple perspectives). Computational demand is minimal. Accessible to learners with varied math backgrounds."

# Content Flags
content_flags:
  - flag: privilege_awareness
    description: "Discussions of income, wealth, and opportunity must acknowledge that not everyone faces identical circumstances or has equal access."
    mitigation: "Emphasize systemic factors alongside individual choice. Acknowledge that good financial decisions require income sufficient for choice, not just discipline."

  - flag: political_sensitivity
    description: "Discussion of taxes, monetary policy, and regulation may reflect political disagreements about government's role."
    mitigation: "Present evidence and multiple perspectives. Focus on reasoning and tradeoffs rather than advocating for particular policies."

