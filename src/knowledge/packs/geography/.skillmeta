# Accessibility
accessibility:
  screen_reader_compatible: true
  large_text_available: true
  high_contrast_available: true
  keyboard_navigable: true
  alt_text_provided: true
  captions_available: false
  notes: "All maps and spatial content have text descriptions. Observation activities include multi-sensory alternatives. Consider adding tactile map resources for visually impaired learners."

# Standards Alignment
standards_alignment:
  - framework: "C3 Framework for Social Studies (Geography)"
    version: 2013
    alignments:
      D2.Geo.1: "Construct maps and other graphic representations of both familiar and unfamiliar places"
      D2.Geo.2: "Use maps, satellite images, photographs, and other representations to explain relationships"
      D2.Geo.3: "Use geographic data to analyze spatial patterns and processes"
      D2.Geo.4: "Analyze the relationships between physical and human geography"

  - framework: "Next Generation Science Standards (Earth & Space Science)"
    version: 2013
    alignments:
      ESS1: "Earth's Place in the Universe"
      ESS2: "Earth's Systems"
      ESS3: "Earth and Human Activity"

# Difficulty Rating
difficulty:
  conceptual_demand: medium
  technical_demand: low
  prerequisites_required: low
  notes: "Conceptual challenge lies in systems thinking and spatial reasoning. Accessible materials and activities at every level."

# Content Flags
content_flags:
  - flag: environmental_sensitivity
    description: "Climate change discussions may intersect with political and economic perspectives."
    mitigation: "Focus on the scientific evidence and geographic analysis. Present data and mechanisms without political advocacy."

  - flag: geopolitical_sensitivity
    description: "Border, sovereignty, and migration topics may touch on contested political issues."
    mitigation: "Use geographic reasoning frameworks. Acknowledge multiple perspectives. Focus on spatial analysis over political positions."

  - flag: cultural_sensitivity
    description: "Discussion of cultural landscapes, indigenous place names, and colonial borders requires cultural awareness."
    mitigation: "Include diverse cultural perspectives. Acknowledge that place names and borders reflect power dynamics. Treat all cultural knowledge with respect."

