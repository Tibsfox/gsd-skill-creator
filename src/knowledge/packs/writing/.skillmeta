# Accessibility
accessibility:
  screen_reader_compatible: true
  large_text_available: true
  high_contrast_available: true
  keyboard_navigable: true
  alt_text_provided: true
  captions_available: false
  notes: "Text-heavy content inherently accessible; peer review tool accessibility. All texts available in audio format for learners with visual impairments. Discussion and peer workshop can be conducted orally."
  pack_specific_concerns:
    - "Peer review tools need accessible commenting and feedback interfaces"
    - "Portfolio platforms need strong keyboard navigation"
    - "Video demonstrations of reading/writing process need captions"
    - "Poetry forms notation must be screen reader compatible"

# Standards Alignment
standards_alignment:
  - framework: "Common Core State Standards (CCSS) ELA"
    version: 2010
    standard_codes:
      - "RL.K.1"
      - "RL.2.1"
      - "RL.4.3"
      - "RL.6.2"
      - "RL.9-10.3"
      - "W.K.3"
      - "W.2.3"
      - "W.4.3"
      - "W.6.3"
      - "W.9-10.3"
    alignments:
      "Reading Literature": "Key details, characters, themes, analysis"
      "Writing": "Narratives, development, revision"

  - framework: "NCTE Standards for English Language Arts"
    version: 2020
    standard_codes:
      - "NCTE.1"
      - "NCTE.3"
      - "NCTE.4"
    alignments:
      "Close Reading": true
      "Reader Response": true
      "Writing Process": true
      "Peer Review": true
      "Diverse Texts": true

  - framework: "IB MYP Language & Literature"
    version: "2014"
    standard_codes:
      - "IB.LANG.1"
      - "IB.LANG.2"
    mappings:
      "Grades 6-10": "Textual analysis, literary response, writing development"

# Difficulty Rating
difficulty:
  conceptual_demand: medium
  technical_demand: low
  prerequisites_required: low
  notes: "Difficulty is in developing habits of thoughtful reading and revision, not in technical content. Accessible to all learners. Foundation level begins with listening and picture books; complexity increases with age."

# Content Flags
content_flags:
  - flag: mature_themes
    description: "Some texts appropriate for older learners address mature themes (loss, discrimination, family conflict) that may be sensitive for younger readers"
    mitigation: "Carefully select texts appropriate for grade level. Provide content warnings and alternative texts when needed. Create space for processing difficult themes."

  - flag: cultural_sensitivity
    description: "Literature includes diverse voices and perspectives; ensure respectful engagement with cultures and experiences beyond learner's own"
    mitigation: "Teach contextual and cultural literacy. Avoid stereotyping or exoticizing texts. Amplify diverse authors and perspectives throughout."

