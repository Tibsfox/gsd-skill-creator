# Accessibility
accessibility:
  screen_reader_compatible: true
  large_text_available: true
  high_contrast_available: true
  keyboard_navigable: true
  alt_text_provided: true
  captions_available: true
  notes: |
    Physical activity descriptions need adaptive alternatives for mobility-limited learners. Video demonstrations have captions and audio descriptions. Every activity includes multiple participation options: adapted movements, supporting roles, observation with analysis. Fitness tracking accessible without wearables (manual logging, verbal reporting). Dance activities include video guides with multiple learning modalities."

# Standards Alignment
standards_alignment:
  - framework: "SHAPE America National Standards for K-12 Physical Education"
    version: 2014
    alignments:
      "Standard 1 (Motor Skills)": "PE-101-M1, M3, M4"
      "Standard 2 (Knowledge & Concepts)": "PE-101-M2, M3, M5"
      "Standard 3 (Fitness)": "PE-101-M2, M5"
      "Standard 4 (Responsibility)": "PE-101-M3, M4, M5"
      "Standard 5 (Value of Activity)": "PE-101-M2, M4, M5"

  - framework: "IB MYP Physical & Health Education"
    version: 2016
    alignments:
      "Health & Social Education": "PE-101-M2, M5"
      "Movement": "PE-101-M1, M3, M4"
      "Physical Activity & Sport": "PE-101-M3, M5"

  - framework: "UK National Curriculum PE"
    version: 2014
    alignments:
      "Key Stage 2": "PE-101-M1, M2, M3 (elementary/middle)"
      "Key Stage 3": "PE-101-M3, M4, M5 (middle/high)"
      "Key Stage 4": "PE-101-M5 (high school)"

  - framework: "Physical Literacy Framework"
    version: 2019
    alignments:
      "Physical Competence": "Motor skills, fitness, and spatial awareness"
      "Daily Behavior": "Active living habits and fitness planning"
      "Motivation and Confidence": "Intrinsic motivation, self-efficacy, enjoyment of movement"
      "Knowledge and Understanding": "Exercise science, rules, strategy, wellness concepts"

# Difficulty Rating
difficulty:
  conceptual_demand: medium
  technical_demand: medium
  prerequisites_required: low
  notes: "Physical skills require practice time. Conceptual content (exercise science, fitness planning) is accessible with scaffolding. All activities adaptable for different ability levels."

# Content Flags
content_flags:
  - flag: body_image_sensitivity
    description: "Physical education activities can trigger body image concerns, especially for adolescents."
    mitigation: "Never use weight, appearance, or body measurements as metrics. Focus on function, capability, and personal growth. Use encouraging language."

  - flag: competition_anxiety
    description: "Competitive activities can create anxiety for less athletic learners."
    mitigation: "Emphasize personal improvement over ranking. Offer modified and cooperative game versions. Never use elimination-style games."

  - flag: physical_limitation_awareness
    description: "Learners with disabilities, chronic illness, or injuries need adapted activities."
    mitigation: "Every module includes adaptation notes. Adapted sports covered explicitly in Module 3. Work with medical professionals for individual plans."

  - flag: cultural_sensitivity_in_dance
    description: "Cultural dance forms must be taught with respect and proper context."
    mitigation: "Partner with cultural organizations. Provide historical and cultural context. Avoid stereotyping or trivializing dance traditions."

