# Accessibility
accessibility:
  screen_reader_compatible: true
  large_text_available: true
  high_contrast_available: true
  keyboard_navigable: true
  alt_text_provided: true
  captions_available: false
  notes: "Field activities include observation guides and verbal descriptions. Climate data uses data tables alongside graphs. Consider adding video demonstrations of environmental processes with captions."

# Standards Alignment
standards_alignment:
  - framework: "Next Generation Science Standards (NGSS)"
    version: 2013
    alignments:
      LS1: "From Molecules to Organisms: Structures and Processes"
      LS2: "Ecosystems: Interactions, Energy, and Dynamics"
      ESS2: "Earth's Systems"
      ESS3: "Earth and Human Activity"

  - framework: "AAAS Benchmarks for Science Literacy"
    version: 1993
    alignments:
      "Life Processes": true
      "Ecosystems": true
      "Earth Systems": true
      "Human Interactions with Environment": true

# Difficulty Rating
difficulty:
  conceptual_demand: medium
  technical_demand: low
  prerequisites_required: low
  notes: "Environmental systems involve invisible processes (cycles, climate) requiring abstract thinking. However, field observation and hands-on activities make content accessible. Prerequisite knowledge helpful but not required."

# Content Flags
content_flags:
  - flag: sensitive_topics
    description: "Climate change and environmental justice can be emotionally charged topics with different family values."
    mitigation: "Distinguish science (observable phenomena) from policy (values-based decisions). Acknowledge different perspectives on solutions while maintaining accuracy on evidence."

  - flag: abstract_concepts
    description: "Food webs, cycles, and feedback loops involve systems students cannot directly observe."
    mitigation: "Use physical models, diagrams, and simulations before abstract representations. Field observation of actual ecosystems builds intuition."

  - flag: data_interpretation
    description: "Climate data includes uncertainty ranges and variability that can be misinterpreted."
    mitigation: "Teach how to read error bars, understand trends vs. noise, and interpret statistical significance. Model critical thinking about data sources."

