      Core Disciplinary Ideas: true
      Manufacturing Technologies: true
      Materials Processing: true

# Difficulty Rating
difficulty:
  conceptual_demand: medium
  technical_demand: medium
  prerequisites_required: low
  notes: "Hands-on material exploration makes entry accessible; manufacturing complexity scales with grade level"

# Content Flags & Warnings
content_flags:
  - flag: safety_considerations
    description: "Fabrication activities involve tools, heat, and materials that require safety awareness"
    mitigation: "Safety guidelines provided for every activity. Age-appropriate tool restrictions. All activities have tool-free alternatives for younger learners."

  - flag: environmental_content
    description: "Pack includes frank discussion of environmental damage from material extraction and manufacturing"
    mitigation: "Focus on empowerment (what can we do better?) rather than despair. Balance problem awareness with solution-oriented thinking."

