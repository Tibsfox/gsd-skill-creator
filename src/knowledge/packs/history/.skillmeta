    name: "Primary Source Analyzer"

  - type: visualization
    name: "Causal Chain Mapper"

  - type: comparison_tool
    name: "Perspective Matrix"

  - type: writing_tool
    name: "Argument Builder"

  - type: timeline
    name: "Interactive Timeline"

