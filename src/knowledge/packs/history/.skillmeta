# Accessibility
accessibility:
  screen_reader_compatible: true
  large_text_available: true
  high_contrast_available: true
  keyboard_navigable: true
  alt_text_provided: true
  captions_available: false
  notes: "All primary source images include detailed text descriptions. Audio sources include transcripts."

# Standards Alignment
standards_alignment:
  - framework: "C3 Framework for Social Studies State Standards"
    version: 2013
    alignments:
      D1: "Developing Questions and Planning Inquiries"
      D2: "Applying Disciplinary Concepts and Tools (History)"
      D3: "Evaluating Sources and Using Evidence"
      D4: "Communicating Conclusions and Taking Informed Action"

  - framework: "National Council for the Social Studies (NCSS)"
    version: 2010
    alignments:
      Time, Continuity, and Change: true
      People, Places, and Environments: true
      Power, Authority, and Governance: true
      Civic Ideals and Practices: true

# Difficulty Rating
difficulty:
  conceptual_demand: high
  technical_demand: low
  prerequisites_required: low
  notes: "Difficulty is in thinking skills, not content volume. Foundation levels are accessible to all learners."

# Content Flags & Warnings
content_flags:
  - flag: sensitive_topics
    description: "History includes violence, injustice, oppression, and suffering. Some primary sources contain disturbing content."
    mitigation: "Age-appropriate source selection at each level. Context and debriefing provided for difficult topics. Learner agency in choosing which topics to explore in depth."

  - flag: multiple_narratives
    description: "Pack explicitly challenges single-narrative history. Learners may encounter perspectives that conflict with family or cultural narratives."
    mitigation: "Frame multiple perspectives as enriching understanding, not attacking existing beliefs. Encourage family dialogue about different viewpoints."

