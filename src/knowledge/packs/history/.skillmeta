    name: "Source Analysis Check"
    frequency: per_activity

  - type: formative
    name: "Causal Reasoning Observation"
    frequency: weekly

  - type: formative
    name: "Perspective-Taking Reflection"
    frequency: per_activity

  - type: summative
    name: "Historical Portfolio"
    frequency: end_of_unit

  - type: summative
    name: "Research Project"
    frequency: end_of_module

