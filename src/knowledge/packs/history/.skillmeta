  - type: textbook
    title: "Thinking Historically"
    author: "Sam Wineburg"
    url: null

# Related Packs
related_packs:
  - id: READ-101
    relationship: "Historical thinking depends on close reading and source analysis skills"

  - id: CRIT-101
    relationship: "Historical argumentation is a domain-specific application of critical thinking"

  - id: GEO-101
    relationship: "Geography provides the spatial context for understanding where and why events occurred"

  - id: PHILO-101
    relationship: "Historical case studies raise philosophical questions about justice, power, and meaning"

  - id: COMM-101
    relationship: "Historical argumentation requires clear communication of complex ideas"

