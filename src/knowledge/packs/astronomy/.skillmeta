# Accessibility
accessibility:
  screen_reader_compatible: true
  large_text_available: true
  high_contrast_available: true
  keyboard_navigable: true
  alt_text_provided: true
  captions_available: true
  notes: |
    Star chart/sky map accessibility essential for blind/low-vision learners. Astronomical image descriptions must be detailed and accurate. Planetarium software (Stellarium, NASA Eyes) requires keyboard navigation and audio description tracks. Video demonstrations include captions and audio descriptions. Observing activities accessible through audio star guides and tactile celestial globe."

# Standards Alignment
standards_alignment:
  - framework: "NGSS Space Systems Standards"
    version: 2013
    alignments:
      "ESS1-1: Patterns of motion of sun, moon, stars": "ASTRO-101-M1, M2"
      "ESS1-2: Earth-moon-sun system interactions": "ASTRO-101-M2"
      "ESS1-3: Gravitational and magnetic forces": "ASTRO-101-M2, M3"
      "ESS1-4: History of Earth": "ASTRO-101-M3, M4, M5"

  - framework: "IAU (International Astronomical Union) Cornerstone Concepts"
    version: 2019
    alignments:
      "The Scale of the Universe": "ASTRO-101-M1, M3, M4, M5"
      "The Nature of Light": "ASTRO-101-M4, M5"
      "The Solar System": "ASTRO-101-M2, M3"
      "The Stars": "ASTRO-101-M4"
      "Galaxies": "ASTRO-101-M5"

  - framework: "IB MYP Sciences (Physics)"
    version: 2016
    alignments:
      "Topic 4: Energy": "ASTRO-101-M4 (stellar fusion)"
      "Topic 5: Motion": "ASTRO-101-M1, M2, M3"
      "Topic 6: Forces": "ASTRO-101-M2, M3, M4"

  - framework: "Common Core Math Standards"
    version: 2010
    alignments:
      "Ratios & Proportional Relationships": "ASTRO-101-M3, M5"
      "Expressions & Equations": "ASTRO-101-M2, M4"
      "Functions": "ASTRO-101-M4 (H-R diagram)"

