    title: "Stanford Encyclopedia of Philosophy"
    author: "Stanford University"
    url: "https://plato.stanford.edu"

  - type: organization
    title: "Philosophy for Children (SAPERE)"
    author: "SAPERE"
    url: "https://www.sapere.org.uk"

  - type: online_resource
    title: "The School of Life"
    author: "The School of Life"
    url: "https://www.theschooloflife.com"

  - type: video
    title: "Wireless Philosophy (Wi-Phi)"
    author: "Wi-Phi"
    url: "https://www.wi-phi.com"

# Related Packs
related_packs:
  - id: "CRIT-101"
    relationship: "Critical thinking skills are grounded in philosophical logic and argumentation"

  - id: "READ-101"
    relationship: "Close reading and textual analysis are essential for philosophical inquiry"

  - id: "HIST-101"
    relationship: "History and philosophy illuminate each other"

  - id: "SCI-101"
    relationship: "Philosophy of science examines foundations of scientific knowledge"

