# Accessibility
accessibility:
  screen_reader_compatible: true
  large_text_available: true
  high_contrast_available: true
  keyboard_navigable: true
  alt_text_provided: true
  captions_available: true
  notes: |
    Safety instructions need multi-modal presentation (text + audio + video). Cooking measurements accessible in multiple formats (cups/metric/weight). Sewing activities include verbal guidance and tactile learning alternatives. Financial tools (spreadsheets, calculators) require keyboard accessibility. Home repair videos include captions and audio descriptions. Laundry symbols require text explanation."

# Standards Alignment
standards_alignment:
  - framework: "NASAFACS Family & Consumer Sciences Standards"
    version: 2018
    alignments:
      "Standard 2.1 (Consumer Resources)": "DOMESTIC-101-M4"
      "Standard 2.5 (Financial Planning)": "DOMESTIC-101-M4"
      "Standard 8.1 (Nutrition & Food Science)": "DOMESTIC-101-M1"
      "Standard 9.1 (Housing & Design)": "DOMESTIC-101-M3"
      "Standard 14.1 (Textiles & Clothing)": "DOMESTIC-101-M2"
      "Standard 14.3 (Care of Textiles)": "DOMESTIC-101-M2"

  - framework: "Jump$tart Coalition Financial Literacy Standards"
    version: 2017
    alignments:
      "Spending and Saving": "DOMESTIC-101-M4"
      "Credit and Debt": "DOMESTIC-101-M4"
      "Financial Decision Making": "DOMESTIC-101-M4"
      "Income": "DOMESTIC-101-M4"

  - framework: "IB MYP Design"
    version: 2016
    alignments:
      "Key Concept: Form": "DOMESTIC-101-M2, M3"
      "Key Concept: Function": "DOMESTIC-101-M1, M2, M3"
      "Key Concept: Aesthetics": "DOMESTIC-101-M2, M3"

  - framework: "Life Skills Standards"
    version: 2020
    alignments:
      "Health & Wellness": "DOMESTIC-101-M1, M5"
      "Personal Finance": "DOMESTIC-101-M4, M5"
      "Home Management": "DOMESTIC-101-M2, M3, M5"

# Difficulty Rating
difficulty:
  conceptual_demand: medium
  technical_demand: medium
  prerequisites_required: low
  notes: "Difficulty is in practice and consistency, not in theory. Conceptually simple but requires hands-on skill development over time."

# Content Flags
content_flags:
  - flag: safety_awareness
    description: "Cooking involves knives and heat. Cleaning involves chemicals. Repairs involve tools. All activities include age-appropriate safety guidance."
    mitigation: "Clear safety protocols for every activity. Younger learners work with adults. Supervision requirements stated explicitly."

  - flag: financial_sensitivity
    description: "Financial activities may surface family financial stress or hardship."
    mitigation: "Activities accommodate all income levels. No shame, no assumptions. Include resources for financial hardship. Simulated money for younger learners."

  - flag: gender_neutrality
    description: "Home economics historically reinforced gender roles. DOMESTIC-101 explicitly rejects gendered domestic expectations."
    mitigation: "Gender-neutral language throughout. All skills taught to all learners. Avoid gendered examples. Celebrate diverse models of domestic competency."

  - flag: food_allergy_awareness
    description: "Cooking activities must accommodate food allergies and dietary restrictions."
    mitigation: "All activities include allergen alternatives. No pressure to eat. Diverse dietary practices respected."

