# Accessibility
accessibility:
  screen_reader_compatible: true
  large_text_available: true
  high_contrast_available: true
  keyboard_navigable: true
  alt_text_provided: true
  captions_available: true
  notes: |
    Safety-critical content needs multi-modal presentation (text + audio + video with captions). Tool diagrams require detailed alt text and 3D tactile models for blind/low-vision learners. Technical drawings accessible via Braille embossing or tactile graphics. Video demonstrations include captions and audio descriptions. Activities adaptable for different mobility levels with tool modifications and assistive devices."

# Standards Alignment
standards_alignment:
  - framework: "NCCER (National Center for Construction Education & Research) Standards"
    version: 2020
    alignments:
      "Safety Protocols": "TRADE-101-M1"
      "Hand & Power Tools": "TRADE-101-M1, M2, M3, M4, M5"
      "Carpentry Basics": "TRADE-101-M2"
      "Electrical Fundamentals": "TRADE-101-M3"
      "Plumbing Systems": "TRADE-101-M4"
      "Welding Basics": "TRADE-101-M5"

  - framework: "Career & Technical Education (CTE) Standards"
    version: 2018
    alignments:
      "Architecture & Construction Cluster": "TRADE-101-M2, M4"
      "Manufacturing Cluster": "TRADE-101-M5"
      "Transportation, Distribution & Logistics": "TRADE-101-M3"

  - framework: "OSHA Safety Standards"
    version: 2020
    alignments:
      "Hazard Recognition": "TRADE-101-M1, M2, M3, M4, M5"
      "PPE Requirements": "TRADE-101-M1, M2, M3, M4, M5"
      "Electrical Safety": "TRADE-101-M3"
      "Tool Safety": "TRADE-101-M1"

  - framework: "Common Core Math Standards"
    version: 2010
    alignments:
      "Measurement & Data": "TRADE-101-M1, M2, M3, M4, M5"
      "Geometry": "TRADE-101-M2, M4"

# Difficulty Rating
difficulty:
  conceptual_demand: medium
  technical_demand: high
  prerequisites_required: medium
  notes: "Skills require supervised hands-on practice. Conceptual demand increases at high school level. Safety is paramount at all levels."

# Content Flags
content_flags:
  - flag: "tool_safety"
    description: "Activities involve real tools with genuine hazard potential"
    mitigation: "Mandatory safety training before tool use. Supervised practice. PPE required. Age-appropriate activities only."

  - flag: "physical_risk"
    description: "Trades activities carry risk of injury"
    mitigation: "Parental consent required. Emergency procedures established. First aid available. Careful project selection for age group."

