# Accessibility
accessibility:
  screen_reader_compatible: true
  large_text_available: true
  high_contrast_available: true
  keyboard_navigable: true
  alt_text_provided: true
  captions_available: false
  notes: "Hands-on activities have text-based alternatives for learners with motor limitations."

# Standards Alignment
standards_alignment:
  - framework: "Next Generation Science Standards (NGSS)"
    version: 2013
    alignments:
      "K-2-ETS1-1": "Ask questions and define problems"
      "3-5-ETS1-1": "Define and delimit engineering problems"
      "MS-ETS1-1": "Define design problems systematically"
      "HS-ETS1-1": "Analyze major global challenges"
      K-2-ETS1: "Engineering Design"
      3-5-ETS1: "Engineering Design"
      MS-ETS1: "Engineering Design"
      HS-ETS1: "Engineering Design"
  - framework: "ITEEA Standards for Technological and Engineering Literacy"
    version: 2020
    alignments:
      "1.A": "Characteristics and scope of technology"
      "2.A": "Core practices of technology"
      "3.A": "Engineering design processes"
      "4.A": "Systemic design and systems"
      Core Disciplinary Ideas: true
      Engineering Design: true
  - framework: "IB Middle Years Programme"
    version: "2024"
    alignments:
      MYP.DES.A: "Investigating and analysing"
      MYP.DES.B: "Developing ideas"
      MYP.DES.C: "Creating the solution"
  - framework: "UK National Curriculum (Design & Technology)"
    version: "2014"
    alignments:
      KS1.DT: "Design and technology curriculum"
      KS2.DT: "Iterative design process"
      KS3.DT: "Engineering and design thinking"

# Difficulty Rating
difficulty:
  conceptual_demand: medium
  technical_demand: medium
  prerequisites_required: low
  notes: "Hands-on focus makes entry accessible; complexity scales with grade level"

# Content Flags & Warnings
content_flags:
  - flag: safety_considerations
    description: "Building activities involve tools, materials, and testing that require safety awareness"
    mitigation: "Safety guidelines provided for every activity. Age-appropriate tool restrictions."

  - flag: failure_normalization
    description: "Pack explicitly celebrates failure as data. Learners accustomed to perfection-oriented environments may need adjustment."
    mitigation: "Gradual introduction. Frame failure as 'data collection' not 'mistakes'. Failure Museum activity normalizes the concept."

# Community & Contribution
community:
  discussion_forum: "https://community.gsd.edu/engr-101"
  contribution_guidelines: "CONTRIBUTING.md"
  open_issues_tag: "ENGR-101"
  looking_for:
