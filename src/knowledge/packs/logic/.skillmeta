# Accessibility
accessibility:
  screen_reader_compatible: true
  large_text_available: true
  high_contrast_available: true
  keyboard_navigable: true
  alt_text_provided: true
  captions_available: false
  notes: "Symbolic logic notation needs MathML; truth table accessibility. Logic games and interactive tools need accessible alternatives."
  pack_specific_concerns:
    - "Symbolic logic notation requires MathML rendering with speech support"
    - "Truth tables need semantic HTML structure for screen readers"
    - "Logic gate circuits need text-based representations"
    - "Logic puzzles need text-based alternatives to visual representations"

# Standards Alignment
standards_alignment:
  - framework: "Common Core Mathematics Standards"
    version: 2010
    standard_codes:
      - "MP3"
      - "MP7"
    alignments:
      MP3: "Construct viable arguments and critique the reasoning of others"
      MP7: "Look for and make use of structure"

  - framework: "C3 Framework for Social Studies"
    version: 2013
    standard_codes:
      - "C3.D3"
      - "C3.D4"
    alignments:
      "Dimension 3": "Evaluate sources and use evidence"
      "Dimension 4": "Construct and defend claims using evidence"

  - framework: "ACM Discrete Structures"
    version: "2013"
    standard_codes:
      - "DM/Logic"
      - "DM/Proof"
    mappings:
      "Foundations": "Propositional logic, proofs"

  - framework: "IB MYP Mathematics"
    version: "2014"
    standard_codes:
      - "IB.MATH.LOG"
    mappings:
      "Grades 6-10": "Logic, reasoning, formal systems"

# Difficulty Rating
difficulty:
  conceptual_demand: medium
  technical_demand: low
  prerequisites_required: low
  notes: "Difficulty increases with age. Foundation level is intuitive; college level requires symbolic fluency."

# Content Flags
content_flags:
  - flag: abstraction_leap
    description: "Transition from concrete to symbolic notation can be challenging"
    mitigation: "Scaffold carefully. Use multiple modalities. Revisit concepts at higher levels."

  - flag: math_anxiety_trigger
    description: "Formal notation may trigger math anxiety in some learners"
    mitigation: "Introduce notation gradually. Emphasize it's shorthand for English ideas."

