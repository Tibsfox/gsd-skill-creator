  - type: online_course
    title: "World Religions Through Their Scriptures"
    author: "Harvard University (edX)"
    url: "https://www.edx.org/learn/religion"

# Related Packs
related_packs:
  - id: "PHILO-101"
    relationship: "Philosophy provides tools of argument, logic, and ethical reasoning that enrich theological study"

  - id: "HIST-101"
    relationship: "Religious history is inseparable from world history; historical thinking essential for context"

  - id: "READ-101"
    relationship: "Reading comprehension and textual analysis skills are foundational for engaging with sacred texts"

  - id: "ART-101"
    relationship: "Religious art and architecture span every culture and period"

  - id: "COMM-101"
    relationship: "Interfaith dialogue requires communication skills and empathetic listening"

