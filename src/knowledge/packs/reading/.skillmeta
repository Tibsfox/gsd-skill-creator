    url: https://www.readworks.org
    description: "Research-based reading comprehension passages with aligned activities"

  - name: commonlit
    url: https://www.commonlit.org
    description: "Free digital library of literary and nonfiction texts"

  - name: newsela
    url: https://newsela.com
    description: "Current events articles at multiple reading levels"

interactive_elements:
  - type: assessment
    name: "Fluency Tracker"

  - type: tool
    name: "Vocabulary Builder"

  - type: visualization
    name: "Story Map Creator"

  - type: game
    name: "Context Clue Detective"

  - type: collaboration
    name: "Peer Reading Conference"

# Translations
translations:
  available:
    - language_code: en
      name: English
      complete: true

    - language_code: es
      name: "Espanol"
      complete: false
      progress: "0%"

  planned: [fr, zh, ar]

# Accessibility
accessibility:
  screen_reader_compatible: true
  large_text_available: true
  high_contrast_available: true
  keyboard_navigable: true
  alt_text_provided: true
  captions_available: false
  notes: "All visual content has text descriptions. Phonics activities include audio components. Dyslexia-friendly font options available. Consider adding text-to-speech support for struggling decoders."

# Standards Alignment
standards_alignment:
  - framework: "Common Core State Standards (ELA)"
    version: 2010
    alignments:
      RF: "Reading: Foundational Skills"
      RI: "Reading: Informational Text"
      RL: "Reading: Literature"
      L: "Language"
      SL: "Speaking and Listening"

  - framework: "Science of Reading Research Base"
    version: 2020
    alignments:
      "Phonemic Awareness": true
      "Phonics": true
      "Fluency": true
      "Vocabulary": true
      "Comprehension": true

# Difficulty Rating
difficulty:
  conceptual_demand: medium
  technical_demand: low
  prerequisites_required: low
  notes: "Difficulty scales with content complexity. Foundational skills are concrete and accessible; critical reading demands grow with text complexity. Accessible to all learners with appropriate scaffolding."

# Content Flags
content_flags:
  - flag: developmental_variation
    description: "Reading development varies enormously among children. Age-based expectations should be used as guidelines, not rigid benchmarks."
    mitigation: "Emphasize progress over milestones. Provide multiple pathways and pacing options. Normalize variation in reading development timelines."

  - flag: learning_difference_sensitivity
    description: "Dyslexia and other reading-related learning differences affect 5-10% of learners. Activities should be inclusive and not shame struggling readers."
    mitigation: "Offer multi-sensory options for all activities. Avoid timed reading as assessment. Separate decoding ability from intelligence or effort."

