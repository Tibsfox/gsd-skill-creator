# Standards Alignment
standards_alignment:
  - framework: "Next Generation Science Standards (NGSS)"
    version: 2013
    alignments:
      SEP-1: "Asking Questions and Defining Problems"
      SEP-3: "Planning and Carrying Out Investigations"
      SEP-4: "Analyzing and Interpreting Data"
      SEP-6: "Constructing Explanations and Designing Solutions"
      SEP-7: "Engaging in Argument from Evidence"

  - framework: "Health Education Standards"
    version: 2007
    alignments:
      "Standard 1": "Students will comprehend concepts related to health promotion and disease prevention"
      "Standard 5": "Students will demonstrate the ability to use decision-making skills to enhance health"

# Difficulty Rating
difficulty:
  conceptual_demand: medium
  technical_demand: low
  prerequisites_required: low
  notes: "Difficulty is in systems thinking and critical evaluation, not in technical content. Accessible to all learners with appropriate scaffolding."

# Content Flags
content_flags:
  - flag: diet_culture_awareness
    description: "Nutrition education sometimes reinforces diet culture (weight focus, food morality). This pack explicitly avoids that language."
    mitigation: "Use 'more often/sometimes' instead of 'good/bad'. Never mention weight or appearance. Center science and joy."

  - flag: food_insecurity_awareness
    description: "Some families experience food insecurity. Nutritional advice without access is not helpful."
    mitigation: "Acknowledge food equity. Provide resources. Avoid shame. Connect to school food programs."

  - flag: food_allergies_and_restrictions
    description: "Learners have diverse food needs and restrictions due to allergies, intolerances, preferences, religion, and values."
    mitigation: "Adapt all activities. Never pressure eating. Use 'I can't' and 'I choose not to' as equally valid. Include diverse cuisines."

  - flag: eating_disorder_risk
    description: "Messaging about food and bodies can trigger or reinforce eating disorders for vulnerable learners."
    mitigation: "Never weight-shame. Avoid restriction language. Include mental health resources. Train educators on trauma-informed nutrition."

