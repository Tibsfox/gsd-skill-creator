# Standards Alignment
standards_alignment:
  - framework: "Council for Economic Education (CEE) Standards"
    version: 2010
    alignments:
      "Standard 1": "Scarcity and choice"
      "Standard 3": "Allocation methods"
      "Standard 7": "Markets and prices"
      "Standard 8": "Price determination"
      "Standard 14": "Entrepreneurship"
  - framework: "Jump$tart Financial Literacy Standards"
    version: 2021
    alignments:
      Spending & Saving: true
      Credit & Debt: true
      Employment & Income: true
      Investing: true
  - framework: "IB Middle Years Programme (Individuals & Societies)"
    version: "2024"
    alignments:
      MYP.IND.A: "Knowing and understanding"
      MYP.IND.D: "Reflecting"
  - framework: "UK National Curriculum (Economics & Enterprise)"
    version: "2014"
    alignments:
      KS2.BUS: "Business and entrepreneurship"
      KS3.BUS: "Economic principles and enterprise"
    alignments:
      "Civic Life": true
      "Foundations of Government": true
      "Role of the Citizen": true

# Difficulty Rating
difficulty:
  conceptual_demand: medium
  technical_demand: low
  prerequisites_required: low
  notes: "Concepts are abstract but grounded in everyday experience; entry is accessible at every level"

# Content Flags & Warnings
content_flags:
  - flag: value_judgments
    description: "Business and legal topics involve value judgments about fairness, justice, and economic systems"
    mitigation: "Pack presents multiple perspectives. Encourages critical thinking over prescribed answers. Explicitly notes when topics are debated."

  - flag: financial_anxiety
    description: "Discussions of money, debt, and financial difficulty may trigger anxiety for learners from financially stressed families"
    mitigation: "Activities use fictional or simulation money. Sensitivity guidance for facilitators. Focus on skills and empowerment, not judgment."

  - flag: legal_variation
    description: "Laws vary significantly by jurisdiction. Pack teaches general principles, not jurisdiction-specific rules."
    mitigation: "Clear disclaimers that laws differ by location. Activities encourage learners to research their local laws."

