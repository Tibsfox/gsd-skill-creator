# Accessibility
accessibility:
  screen_reader_compatible: true
  large_text_available: true
  high_contrast_available: true
  keyboard_navigable: true
  alt_text_provided: true
  captions_available: false
  notes: "All visual content has text descriptions. Experiment instructions include verbal/tactile alternatives. Video captions planned."

# Standards Alignment
standards_alignment:
  - framework: "Next Generation Science Standards (NGSS)"
    version: 2013
    alignments:
      "K-PS2-1": "Objects and motion"
      "1-PS4-1": "Sound and vibrations"
      "2-PS1-1": "Matter and its properties"
      "3-PS2-1": "Forces and motion"
      "4-PS3-1": "Energy in motion"
      "5-PS2-1": "Forces and interactions"
      PS1: "Matter and Its Interactions"
      PS2: "Motion and Stability: Forces and Interactions"
      PS3: "Energy"
      PS4: "Waves and Their Applications"
  - framework: "AP Physics 1 & 2"
    version: 2024
    alignments:
      "1.A": "Kinematics"
      "2.A": "Dynamics"
      "3.A": "Energy and work"
      "4.A": "Waves and sound"
      "5.A": "Electricity and magnetism"
  - framework: "IB Middle Years Programme (Sciences)"
    version: "2024"
    alignments:
      MYP.PHY.A: "Knowing and understanding"
      MYP.PHY.B: "Investigating"
      MYP.PHY.C: "Communicating"
  - framework: "UK National Curriculum (Science - Physics)"
    version: "2014"
    alignments:
      KS3.PHY: "Forces, energy, waves"
      KS4.PHY: "Matter and energy"

# Difficulty Rating
difficulty:
  conceptual_demand: high
  technical_demand: moderate
  prerequisites_required: low
  notes: "Conceptually deep but uses everyday materials; math demand scales with grade level"

# Content Flags & Warnings
content_flags:
  - flag: physics_anxiety
    description: "Some learners have physics or math anxiety that may surface during quantitative work"
    mitigation: "Pack emphasizes conceptual understanding before formalism; qualitative reasoning always precedes equations"

  - flag: counterintuitive_results
    description: "Several physics concepts contradict everyday intuition (e.g., objects fall at the same rate regardless of mass)"
    mitigation: "Misconceptions are addressed explicitly with hands-on demonstrations"

  - flag: modern_physics_concepts
    description: "Module 5 covers topics like relativity and quantum mechanics that challenge classical intuition"
    mitigation: "Presented as extensions of classical physics with clear connections to evidence and observation"

