  - type: interactive
    title: "Seeing Theory"
    author: "Brown University"
    url: "https://seeing-theory.brown.edu/"

# Related Packs
related_packs:
  - id: MATH-101
    relationship: "Arithmetic and algebra provide quantitative foundations for accounting and statistics"

  - id: DATA-101
    relationship: "Data science extends statistical analysis with computational tools"

  - id: ECON-101
    relationship: "Economics applies accounting measurement and statistical analysis to markets and policy"

  - id: CRIT-101
    relationship: "Critical thinking skills strengthen evaluation of statistical and financial claims"

