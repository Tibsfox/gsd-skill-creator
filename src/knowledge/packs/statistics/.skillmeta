# Standards Alignment
standards_alignment:
  - framework: "Common Core State Standards (Math - Statistics)"
    version: "2010"
    alignments:
      "CCSS.MATH.6.SP.A": "Develop understanding of statistics"
      "CCSS.MATH.7.SP.A": "Use random sampling"
      "CCSS.MATH.S-ID.A": "Summarize, represent, interpret data"
      "CCSS.MATH.S-IC.A": "Understand and evaluate random processes"
      S-CP: "Conditional Probability & Rules of Probability"
  - framework: "Jump$tart Financial Literacy Standards"
    version: "2017"
    alignments:
      Spending & Saving: "true"
      Credit & Debt: "true"
      Financial Responsibility: "true"
  - framework: "IB Middle Years Programme (Mathematics)"
    version: "2024"
    alignments:
      MYP.STAT.A: "Knowing and understanding"
      MYP.STAT.B: "Investigating"
  - framework: "UK National Curriculum (Statistics & Probability)"
    version: "2014"
    alignments:
      KS2.STAT: "Data handling and probability"
      KS3.STAT: "Statistical averages and spread"

# Difficulty Rating
difficulty:
  conceptual_demand: high
  technical_demand: low
  prerequisites_required: low
  notes: "Difficulty is in understanding what numbers mean, not in performing calculations"

# Content Flags & Warnings
content_flags:
  - flag: anxiety_potential
    description: "Some learners have math anxiety that extends to statistics and financial topics."
    mitigation: "Focus on meaning and application, not speed or memorization. Normalize uncertainty."

  - flag: socioeconomic_sensitivity
    description: "Financial literacy topics may surface family economic differences."
    mitigation: "Use fictional scenarios for budgeting. Never require sharing personal financial information."

  - flag: prior_misconceptions
    description: "Common statistical misconceptions (gambler's fallacy, correlation/causation) are deeply ingrained."
    mitigation: "Address misconceptions directly with experiential counterexamples, not just verbal correction."

