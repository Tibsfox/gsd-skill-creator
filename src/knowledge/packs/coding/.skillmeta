    title: "Structure and Interpretation of Computer Programs (SICP)"
    author: "Sussman & Abelson"

  - type: "foundational_text"
    title: "Algorithm Design Manual"
    author: "Steven Skiena"

  - type: "online_course"
    title: "Crash Course Computer Science"
    url: "https://www.youtube.com/playlist?list=PLME-KWdxI8dcKn2QY4tVU32-8S-0RJhTN"

# Related Packs
related_packs:
  - id: MATH-101
    relationship: "Algorithms use mathematical reasoning; data structures use set theory"

  - id: PROB-101
    relationship: "Probability algorithms; simulation and modeling"

  - id: DATA-101
    relationship: "Programming is how data is collected, cleaned, and analyzed"

  - id: DIGLIT-101
    relationship: "Digital literacy grounded in computational understanding"

