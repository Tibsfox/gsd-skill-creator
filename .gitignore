extra/man/*.1
extra/man/*.5

# Coverage
coverage/
.college/coverage/

# === Filesystem Zones (v1.49.4) ===

# User workspace (personal, not shared)
projects/*/
!projects/README.md
!projects/.gitkeep

# Contrib staging (ephemeral review artifacts)
contrib/downstream/staging/*/
contrib/upstream/*/
!contrib/upstream/.gitkeep
!contrib/README.md

# WWW generated output
www/site/*/
www/staging/*/
!www/tools/
!www/README.md

# Local project data
media/
www/www.zip

# User-local config
.sc-config.json
the-space-between-engine/package-lock.json
