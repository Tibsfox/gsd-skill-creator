# Build output
dist/

# Dependencies
node_modules/

# Planning docs (local only)
.planning/
.claude/
.cpanel.yml

# Brainstorm session data (local only)
.brainstorm/

# Generated dashboard (root-level only, not src/dashboard/ or src/citations/dashboard/)
/dashboard/

# Tauri / Desktop
src-tauri/target/
src-tauri/gen/
desktop/dist/
desktop/node_modules/

# Citation cache (regenerable API responses)
.citations/cache/

# Coverage
coverage/

# === Filesystem Zones (v1.49.4) ===

# User workspace (personal, not shared)
projects/*/
!projects/README.md
!projects/.gitkeep

# Contrib staging (ephemeral review artifacts)
contrib/downstream/staging/*/
contrib/upstream/*/
!contrib/upstream/.gitkeep
!contrib/README.md

# WWW generated output
www/site/*/
www/staging/*/
!www/tools/
!www/README.md

# User-local config
.sc-config.json
