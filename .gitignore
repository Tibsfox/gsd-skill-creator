dist/

# Dependencies
node_modules/

# Planning docs (local only)
.planning/
.claude/
.cpanel.yml

# Brainstorm session data (local only)
.brainstorm/

# Archive (deprecated code, hidden)
.archive/

# Generated dashboard (infra/dashboard/, not src/dashboard/)
infra/dashboard/*.html
infra/dashboard/.dashboard-manifest.json

# Tauri / Desktop
src-tauri/target/
src-tauri/gen/
desktop/dist/
desktop/node_modules/

