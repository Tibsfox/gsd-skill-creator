{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "gsd-os-default",
  "description": "Default capabilities for GSD-OS main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:event:default",
    "allow-greet",
    "allow-echo-event",
    "allow-echo-channel",
    "allow-ipc-benchmark",
    "allow-ipc-benchmark-channel"
  ]
}
